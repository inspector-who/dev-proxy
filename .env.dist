COMPOSE_PROJECT_NAME=dev-proxy

# Traefik shared network name
TRAEFIK_NETWORK=traefik

# Traefik ports (host side). You can override these if 80/443/8081 are busy on your machine.
# Examples:
# TRAEFIK_PORT_HTTP=8080
# TRAEFIK_PORT_HTTPS=8443
# TRAEFIK_PORT_DASHBOARD=8082
TRAEFIK_PORT_HTTP=80
TRAEFIK_PORT_HTTPS=443
TRAEFIK_PORT_DASHBOARD=8081
